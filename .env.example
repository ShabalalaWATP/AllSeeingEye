# Copy this file to .env and fill in your key. The .env file is gitignored.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
# Optional voice-note transcription model.
# OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
# Optional, only for reasoning models (cuts latency). Leave unset otherwise.
# OPENAI_REASONING_EFFORT=low
# Quick takes default to low reasoning even when full reviews use a higher effort.
# OPENAI_QUICK_REASONING_EFFORT=low
