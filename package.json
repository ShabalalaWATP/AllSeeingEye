{
  "name": "allseeingeye",
  "version": "0.1.0",
  "description": "AllSeeingEye is an on-demand, multi-agent red-team reviewer for screens, windows, text and voice notes.",
  "main": "./out/main/index.js",
  "author": "Alex Orr",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "build": "electron-vite build",
    "package:win": "npm run build && electron-builder --win portable",
    "package:dir": "npm run build && electron-builder --dir",
    "preflight": "node scripts/preflight.mjs",
    "vendor:eye": "node scripts/vendor-evil-eye.mjs"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron-store": "^8.2.0",
    "openai": "^6.48.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "ogl": "^1.0.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^3.2.7"
  }
}
